# Docker Compose host settings (non-secret names)
POLARIS_BIND_ADDRESS=
POLARIS_PORT=
POLARIS_DATA_PATH=
POLARIS_WORKSPACE_PATH=
POLARIS_EXPORT_PATH=
POLARIS_SECRETS_PATH=
POLARIS_UID=
POLARIS_GID=
