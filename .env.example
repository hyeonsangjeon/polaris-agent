# Variable names only. Set values in an owner-only secret manager/runtime file.

# Polaris paths
POLARIS_HOME=
POLARIS_CONFIG=
POLARIS_SECRETS_FILE=

# Provider authentication
AZURE_FOUNDRY_API_KEY=

# Private channels
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
