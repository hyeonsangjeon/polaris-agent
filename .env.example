# Copy only the variables needed by your selected provider. Never commit values.

# Optional path overrides
POLARIS_HOME=/absolute/path/to/private/polaris-state
# POLARIS_CONFIG=/absolute/path/to/config.json

# Foundry Model Router API-key authentication
AZURE_FOUNDRY_API_KEY=

# Docker Compose host settings
POLARIS_BIND_ADDRESS=127.0.0.1
POLARIS_PORT=8765
POLARIS_DATA_PATH=./.polaris-data
POLARIS_WORKSPACE_PATH=./workspace
POLARIS_EXPORT_PATH=./exports
