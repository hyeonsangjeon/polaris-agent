{
  "data_dir": "/ABSOLUTE/PATH/TO/POLARIS_HOME",
  "providers": {
    "ollama": {
      "kind": "ollama",
      "model": "llama3.2",
      "base_url": "http://127.0.0.1:11434"
    }
  },
  "tools": {
    "roots": [
      "/ABSOLUTE/PATH/TO/WORKSPACE"
    ],
    "allow_private_http": false
  },
  "daemon": {
    "host": "127.0.0.1",
    "port": 8765,
    "token_file": "/ABSOLUTE/PATH/TO/POLARIS_HOME/api-token",
    "secrets_file": "/ABSOLUTE/PATH/TO/POLARIS_HOME/runtime-secrets.env"
  },
  "memory": {
    "enabled": true,
    "profile_id": "default",
    "char_budget": 12000,
    "tool_enabled": true
  },
  "scheduler": {
    "enabled": true
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token_env": "TELEGRAM_BOT_TOKEN",
      "allowed_user_ids": [
        123456789
      ],
      "allowed_chat_ids": [
        123456789
      ],
      "default_provider": "ollama"
    },
    "slack": {
      "enabled": false
    }
  },
  "offline": {
    "enabled": false
  }
}
